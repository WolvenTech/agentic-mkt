# =============================================================================
# agentic-mkt — local secrets (copy to .env, never commit .env)
# =============================================================================
# Powers: local TypeScript CLI scripts, the vendor gate, optional live tests, and Cursor MCP servers.
# Load via: automatic for `pnpm vendor:gate` and all TS CLI scripts (src/load-env.ts) — reads
# repo-root .env unless SKIP_DOTENV=1. Or export / direnv.
#
# Vendor gate: `pnpm vendor:gate` checks CLICKUP_API_TOKEN, CLICKUP_LIST_ID, and N8N_API_KEY plus
# live ClickUp/n8n connectivity before any live test tier (`pnpm test:live`) or live CLI validation
# runs. See root README "Vendor gate".
#
# NOT in this file: production n8n credentials (ClickUp, Gemini API key)
# configured in n8n.wolven.com.br UI — see n8n/README.md.

# --- ClickUp (local scripts + ClickUp MCP) ---
# Used by: `pnpm clickup:sync`, `pnpm clickup:verify`, optional tests
# MCP: @griffinwork40/clickup-mcp-server (env: CLICKUP_API_TOKEN)
# Get token: ClickUp → Settings → Apps → API (see clickup/README.md)
# List ID: Marketing Pipeline list URL (.../v/li/{id})
CLICKUP_API_TOKEN=pk_your_token_here
CLICKUP_LIST_ID=your_list_id_here

# --- n8n API (n8n MCP — workflow management from Cursor) ---
# Used by: czlonkowski/n8n-mcp (N8N_API_URL + N8N_API_KEY)
# API key: n8n.wolven.com.br → Settings → API
N8N_API_URL=https://n8n.wolven.com.br
N8N_API_KEY=n8n_api_your_key_here
# Optional: n8n built-in MCP HTTP endpoint (separate from REST API key)
# N8N_MCP_TOKEN=your_n8n_mcp_bearer_token

# --- Google Gemini (local testing outside n8n) ---
# Used by: local LLM / MCP experimentation (M1 model: gemini-2.5-flash)
# Get key: https://aistudio.google.com/apikey
# Production pipeline uses n8n Google AI credential — not this file.
GOOGLE_API_KEY=your_google_ai_api_key_here
